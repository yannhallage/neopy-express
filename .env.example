NODE_ENV=development
PORT=3000

# Neon : « Pooled connection » (souvent host …-pooler…)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon : « Direct connection » (sans pooler) — requis pour `prisma migrate`
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Optionnel : `npm run db:seed` (sinon admin@example.com / Premier utilisateur)
# SEED_USER_EMAIL="vous@exemple.com"
# SEED_USER_NAME="Votre nom"
